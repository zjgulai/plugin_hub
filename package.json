{
  "name": "plugin-hub",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "test": "pnpm test:api && pnpm -r test",
    "test:api": "uv --directory apps/api run pytest",
    "lint": "pnpm lint:api && pnpm -r lint",
    "lint:api": "uv --directory apps/api run ruff check .",
    "typecheck": "pnpm typecheck:api && pnpm -r typecheck",
    "typecheck:api": "uv --directory apps/api run mypy"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
